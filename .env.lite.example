# Lightweight VPS demo profile.
# Copy to .env.lite on the server, fill only Volcengine Ark values, then run:
#   npm run demo:lite:check -- --env-file .env.lite
#   docker compose --env-file .env.lite -f docker-compose.lite.yml up --build -d

PUBLIC_WEB_BASE_URL=http://proveo.devhub.ccwu.cc
PUBLIC_API_BASE_URL=http://proveo.devhub.ccwu.cc
OBJECT_STORAGE_PUBLIC_BASE_URL=http://proveo.devhub.ccwu.cc/objects
ALLOWED_ORIGINS=http://proveo.devhub.ccwu.cc,http://localhost,http://127.0.0.1

POSTGRES_PASSWORD=postgres
API_PORT=5001
WEB_PORT=80
NODE_OPTIONS=--max-old-space-size=256

# Fill cloud provider keys only when you want those remote calls enabled.
# Qingyun / Qwen-VL must stay empty for this VPS profile.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_TEXT_MODEL_ID=
ARK_VIDEO_MODEL_ID=
ARK_ENABLE_TEXT=true
ARK_ENABLE_VIDEO=true
SPEC_ENABLE_SEEDANCE=true

# Keep the VPS demo cheap and stable on ~1GB RAM.
SEEDANCE_CONCURRENCY=1
SEEDANCE_REQUEST_DURATION_SECONDS=5
SEEDANCE_MAX_ATTEMPTS=3
WORKER_LOCK_DURATION_MS=900000
AGENT_WORKER_CONCURRENCY=1
SCRIPT_WORKER_CONCURRENCY=1
RENDER_WORKER_CONCURRENCY=1
MATERIAL_WORKER_CONCURRENCY=1
MAINTENANCE_WORKER_CONCURRENCY=1

# Optional remote image providers. Keep local/off on a low-memory VPS unless needed.
QWEN_IMAGE_PROVIDER=local
GPTIMAGE2_PROVIDER=off
TRUSTLOOP_WEB_SEARCH=false
TREND_REFRESH_ENABLED=false
TREND_ENRICH_ENABLED=false
VECTOR_REINDEX_ENABLED=false
VECTOR_STORE_PROVIDER=off
CLIP_ENABLED=false
CLIP_WARMUP_ENABLED=false
PGVECTOR_ENABLED=false
QDRANT_ENABLED=false
