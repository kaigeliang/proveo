{
  "name": "aigc-video-hub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "./setup.sh",
    "install:all": "npm install",
    "dev": "node scripts/check-local-services.mjs && concurrently \"npm run dev --prefix apps/api\" \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/worker\"",
    "dev:local": "npm run services:up && npm run db:generate && npm run db:deploy && npm run dev",
    "dev:prod": "npm run dev",
    "dev:up": "./start.sh --detach",
    "dev:down": "./stop.sh",
    "dev:up:services": "./start.sh --detach --with-services",
    "dev:down:services": "./stop.sh --with-services",
    "services:up": "docker compose up -d --wait postgres redis minio qdrant",
    "services:down": "docker compose down",
    "demo:lite:check": "node scripts/check-lite-demo-env.mjs",
    "demo:lite:up": "docker compose --env-file .env.lite -f docker-compose.lite.yml up --build -d",
    "demo:lite:down": "docker compose --env-file .env.lite -f docker-compose.lite.yml down",
    "dev:api": "npm run dev --prefix apps/api",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:worker": "npm run dev --prefix apps/worker",
    "build": "npm run build --prefix packages/db && npm run build --prefix packages/storage && npm run build --prefix packages/queue && npm run build --prefix packages/agent-runtime && npm run build --prefix packages/trustloop && npm run build --prefix apps/web && npm run build --prefix apps/api && npm run build --prefix apps/worker",
    "build:packages": "npm run build --prefix packages/db && npm run build --prefix packages/storage && npm run build --prefix packages/queue && npm run build --prefix packages/agent-runtime && npm run build --prefix packages/trustloop",
    "build:api": "npm run build --prefix apps/api",
    "build:web": "npm run build --prefix apps/web",
    "build:worker": "npm run build --prefix apps/worker",
    "lint": "npm run lint --prefix apps/web && npm run lint --prefix apps/api",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md,yml,yaml}\"",
    "format:check:staged": "node scripts/check-staged-format.mjs",
    "stylelint": "stylelint \"apps/web/src/**/*.css\"",
    "test:spec": "node scripts/spec-smoke.mjs",
    "test:clonecast": "node scripts/smoke-clonecast.mjs",
    "test:agent-chat": "node --env-file=.env scripts/smoke-agent-chat.mjs",
    "test:agent-ui": "node scripts/smoke-agent-ui-protocol.mjs",
    "test:mastra-workflow": "node scripts/smoke-mastra-workflow.mjs",
    "test:p0:snapshot": "node scripts/smoke-p0-project-snapshot.mjs",
    "test:p0:real-e2e": "node scripts/smoke-p0-real-e2e.mjs",
    "clip:prewarm": "node scripts/prewarm-clip.mjs",
    "trends:refresh": "node scripts/refresh-trends.mjs",
    "crawl:refs": "node scripts/crawl-reference-videos.mjs",
    "download:ref": "node scripts/download-reference-video.mjs",
    "kalodata:prepare": "node scripts/ingest-kalodata-exports.mjs",
    "fastmoss:ingest": "node scripts/ingest-fastmoss-exports.mjs",
    "ml:export-dataset": "node scripts/export-scorer-dataset.mjs",
    "ml:ablate": "python3 scripts/ablate-creative-factors.py",
    "references:index": "node scripts/index-reference-vectors.mjs",
    "qwen:select": "node scripts/select-qwenvl-candidates.mjs",
    "qwen:smoke": "node scripts/run-qwenvl-smoke.mjs",
    "qwen:url": "node scripts/run-qwenvl-url-batch.mjs",
    "qwen:audit": "node scripts/audit-qwenvl-quality.mjs",
    "qwen:ingest": "node scripts/ingest-qwenvl-truth.mjs",
    "qwen:reference": "node scripts/run-qwenvl-reference-analysis.mjs",
    "qwen:reindex": "node scripts/reindex-qwenvl-reference-vectors.mjs",
    "subtitles:ingest": "node scripts/ingest-subtitle-style-slices.mjs",
    "subtitles:decompose": "node scripts/run-qwenvl-subtitle-style-batch.mjs",
    "scorer:train": "python3 scripts/train-benchmark-scorer.py",
    "scorer:qwen-train": "python3 scripts/train-qwenvl-scorer.py",
    "videos:download": "node scripts/download-tiktok-videos.mjs",
    "videos:analyze": "node scripts/analyze-tiktok-videos.mjs",
    "normalize:materials": "node scripts/normalize-materials.mjs",
    "vectors:recompute": "node scripts/recompute-slice-embeddings.mjs",
    "prepare": "husky || true",
    "start": "concurrently \"npm run start --prefix apps/api\" \"npm run start --prefix apps/worker\"",
    "start:api": "npm run start --prefix apps/api",
    "start:worker": "npm run start --prefix apps/worker",
    "db:generate": "npm run prisma:generate --prefix packages/db",
    "db:migrate": "npm run prisma:migrate --prefix packages/db",
    "db:deploy": "npm run prisma:deploy --prefix packages/db",
    "db:studio": "npm run prisma:studio --prefix packages/db"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "playwright": "^1.60.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "read-excel-file": "^9.0.10",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.7.2"
  }
}
