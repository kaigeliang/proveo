# Copy to .env and fill private values for your private team repo.

PORT=5001
PUBLIC_API_BASE_URL=http://localhost:5001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Queue is the only task runtime: API writes Postgres tasks and BullMQ jobs; Worker executes them.
PIPELINE_MODE=queue
USE_PRODUCTION_PIPELINE=true
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/aigc_video_hub
REDIS_URL=redis://127.0.0.1:6379
WORKER_LOCK_DURATION_MS=900000
# Local developer machines that cannot reach Volcengine Ark directly should set these to their local proxy.
HTTP_PROXY=
HTTPS_PROXY=

# Local object storage is enough for local development; MinIO/S3 can be enabled with OBJECT_STORAGE_DRIVER=s3.
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_LOCAL_ROOT=tmp/object-storage

# Volcengine Ark / Doubao / Seedance.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_TEXT_MODEL_ID=
ARK_VIDEO_MODEL_ID=
ARK_ENABLE_TEXT=true
ARK_ENABLE_VIDEO=true
SPEC_ENABLE_SEEDANCE=true
SEEDANCE_CONCURRENCY=5
# Seedance 429/限流重试：指数退避（base*2^n，封顶 cap），遵循 Retry-After；非可重试错误快速失败。
SEEDANCE_MAX_ATTEMPTS=5
SEEDANCE_RETRY_BASE_MS=4000
SEEDANCE_RETRY_CAP_MS=45000
# 命中 429 后的全局冷却窗口(ms)：期间所有 Seedance 调用统一退避，成功即清除
SEEDANCE_COOLDOWN_MS=15000
# 当前 doubao-seedance-1-5-pro 已验证会拒绝 --dur 2；默认按 5s 生成，再由 FFmpeg 裁切到剧本分镜时长。
SEEDANCE_REQUEST_DURATION_SECONDS=5
# Local object URLs are not cloud-reachable by Seedance; allow true Seedance T2V instead of failing local P0 smoke.
SEEDANCE_ALLOW_T2V_FALLBACK=true
RENDER_WORKER_CONCURRENCY=3
ARK_TIMEOUT_MS=90000
ARK_VIDEO_TIMEOUT_MS=240000
ARK_VIDEO_POLL_MS=4000

# Optional Qwen image edit provider for real multi-angle product references.
# Set QWEN_IMAGE_PROVIDER=local to force local fallback angle cards.
QWEN_IMAGE_PROVIDER=auto
QWEN_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
QWEN_IMAGE_API_KEY=
DASHSCOPE_API_KEY=
QWEN_IMAGE_MODEL_ID=qwen-image-2.0-pro
QWEN_IMAGE_TIMEOUT_MS=120000

# Optional Qwen-VL video understanding batch runner for Kalodata truth slices.
QWEN_VL_BASE_URL=
QWEN_VL_API_KEY=
QWEN_VL_MODEL_ID=qwen3-vl-plus
QWEN_VL_MEDIA_UPLOAD_URL=https://api.qingyuntop.top/openapi/v2/media/upload
QWEN_VL_SUBTITLE_TIMEOUT_MS=45000
QWEN_VL_SUBTITLE_FPS=1
QWEN_VL_SUBTITLE_MAX_TOKENS=900
QWEN_ATTRIBUTION_PATH=tmp/kalodata-test/qwenvl-url-ingested-v2/qwenvl-factor-attribution-v1.json

# Optional product reference T2I provider used before Seedance I2V when no merchant product image exists.
# Set GPTIMAGE2_PROVIDER=local/off to disable. OPENAI_API_KEY is also accepted if GPTIMAGE2_API_KEY is blank.
GPTIMAGE2_PROVIDER=auto
GPTIMAGE2_BASE_URL=https://api.openai.com/v1/images/generations
GPTIMAGE2_API_STYLE=images
GPTIMAGE2_API_KEY=
GPTIMAGE2_MODEL_ID=gpt-image-2
GPTIMAGE2_SIZE=1024x1024
GPTIMAGE2_QUALITY=low
GPTIMAGE2_OUTPUT_FORMAT=png
GPTIMAGE2_BACKGROUND=auto
GPTIMAGE2_RESPONSE_FORMAT=
GPTIMAGE2_TIMEOUT_MS=300000
GPTIMAGE2_IMAGE_FETCH_TIMEOUT_MS=90000

# Optional: generate a GPTImage2 image-guided last frame from the first frame, then call Seedance with first_frame/last_frame roles.
# This improves continuity but roughly doubles image-generation latency/cost for generated shots.
SEEDANCE_FIRST_LAST_FRAME_ENABLED=false

# Continuity strategy (auto-routed by default to keep the product identical across shots):
#   - Real merchant product image present  -> multi-angle I2V: every shot is seeded from that same
#     real image (concurrent), so the product stays identical while the camera angle/framing changes.
#   - No real product image                -> per-shot Seedance T2V: each request uses the safe 5s
#     duration window, then FFmpeg trims and stitches. Whole-video is opt-in because long duration
#     prompts may be rejected by the current Seedance endpoint.
SEEDANCE_WHOLE_VIDEO_AUTO=false

# Frame-chaining (opt-in, off by default): the real last frame of each shot becomes the next shot's
# I2V first frame, welding shots into one continuous motion. Use only for single continuous-action
# moments; it forces serial generation and prevents angle cuts. Requires cloud-reachable storage URLs.
SEEDANCE_FRAME_CHAIN_ENABLED=false

# Optional: only enable if your model/account supports Doubao web_search tools.
TRUSTLOOP_WEB_SEARCH=false

# Required by the queue runtime.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/aigc_video_hub
REDIS_URL=redis://127.0.0.1:6379
AGENT_ORCHESTRATION_ENABLED=true
TREND_REFRESH_ENABLED=true
TREND_REFRESH_INTERVAL_MINUTES=60
TREND_MAX_ITEMS=80
TREND_ENRICH_ENABLED=true
TREND_ENRICH_PROVIDER=auto
TREND_ENRICH_MAX_ITEMS=12
TREND_ENRICH_BATCH_SIZE=4
TREND_ENRICH_TTL_HOURS=168
TREND_ENRICH_TIMEOUT_MS=45000
VECTOR_REINDEX_ENABLED=true
VECTOR_REINDEX_INTERVAL_MINUTES=240
VECTOR_REINDEX_MAX_ITEMS=2000
VECTOR_STORE_PROVIDER=qdrant
PGVECTOR_ENABLED=false
PGVECTOR_DIMS=1024
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
QDRANT_ENABLED=true
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=aigc_video_clip_vectors
QDRANT_DIMS=1024
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT_MS=5000
# Optional local JSON seed file with {items:[{title,category,product,tags,metrics}]}.
TREND_SEED_FILE=

# S3/MinIO-compatible storage for production mode.
OBJECT_STORAGE_BUCKET=aigc-video-hub
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:5001/objects

QDRANT_REFERENCE_COLLECTION=aigc_reference_vectors
