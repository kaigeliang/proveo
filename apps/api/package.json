{
  "name": "aigc-video-server",
  "version": "1.0.0",
  "description": "Express server for E-commerce AIGC video generation system",
  "main": "dist/apps/api/src/index.js",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "tsc && node scripts/copy-build-assets.mjs",
    "lint": "tsc --noEmit",
    "start": "node dist/apps/api/src/index.js"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.54",
    "@aigc-video-hub/db": "1.0.0",
    "@aigc-video-hub/queue": "1.0.0",
    "@aigc-video-hub/storage": "1.0.0",
    "@aigc-video-hub/trustloop": "1.0.0",
    "@huggingface/transformers": "^4.2.0",
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
